# Copia este archivo a ".env" (sin ".example") y pon tus valores reales.
# En Render, estas mismas variables se configuran desde el panel de "Environment", no en este archivo.
DATABASE_URL=postgresql://usuario:password@host.neon.tech/basedatos?sslmode=require

# Google OAuth ("Continuar con Google"), desde Google Cloud Console > APIs y servicios > Credenciales
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx

# Correos (separados por coma) que pueden gestionar la lista blanca de "Continuar con
# Google" desde admin/usuarios_autorizados.php. El registro público está cerrado.
SUPERADMIN_EMAILS=tu-correo@gmail.com
